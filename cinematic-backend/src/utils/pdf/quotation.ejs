<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Quotation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        <%- css %>
    </style>
</head>

<body>
    <div class="page">
        <!-- Header -->
        <header class="header">
            <div class="company-info">
                <div class="company-name">Aura Cinematic Weddings</div>
                <div class="company-tagline">Cinematic Weddings</div>
                <div class="company-contact">
                    +91 080 234 5789 | www.auraweddings.com<br>
                    hello@auraweddings.com
                </div>
            </div>
            
            <div class="invoice-details">
                <h1>QUOTATION</h1>
                <div class="meta-grid">
                    <span class="meta-label">Quotation ID:</span>
                    <span class="meta-value">Q-<%= invoice.number %></span>
                    
                    <span class="meta-label">Date:</span>
                    <span class="meta-value"><%= invoice.date %></span>
                </div>
            </div>
        </header>

        <!-- Aesthetic Grid (Insta Style) -->
        <div class="aesthetic-grid">
            <img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=800&auto=format&fit=crop" crossorigin="anonymous" class="hero-img">
            <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=800&auto=format&fit=crop" crossorigin="anonymous" class="side-img">
            <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=800&auto=format&fit=crop" crossorigin="anonymous" class="side-img">
        </div>

        <!-- Billing Section -->
        <div class="billing-section">
            <div class="billing-block left">
                <div class="section-label">Quotation For</div>
                <div class="client-name"><%= client.name %></div>
                
                <% if (client.phone && client.phone !== '-') { %>
                <div class="client-details-row">
                    <span class="client-details-label">Phone:</span>
                    <span class="client-details-val"><%= client.phone %></span>
                </div>
                <% } %>
                
                <% if (client.address && client.address !== '-') { %>
                <div class="client-details-row">
                    <span class="client-details-label">Address:</span>
                    <span class="client-details-val"><%= client.address %></span>
                </div>
                <% } %>
            </div>
            
            <div class="billing-block right">
                <div class="inner-details">
                    <div class="section-label">Event Details</div>
                    
                    <div class="client-details-row">
                        <span class="client-details-label">Event Type:</span>
                        <span class="client-details-val"><%= event.type || '-' %></span>
                    </div>
                    
                    <% if (event.date && event.date !== '-') { %>
                    <div class="client-details-row">
                        <span class="client-details-label">Event Date:</span>
                        <span class="client-details-val"><%= event.date %></span>
                    </div>
                    <% } %>
                    
                    <% if (event.venue && event.venue !== '-') { %>
                    <div class="client-details-row">
                        <span class="client-details-label">Venue:</span>
                        <span class="client-details-val"><%= event.venue %></span>
                    </div>
                    <% } %>
                    
                    <% if (event.guestCount && event.guestCount !== '-') { %>
                    <div class="client-details-row">
                        <span class="client-details-label">Guest Count:</span>
                        <span class="client-details-val"><%= event.guestCount %></span>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

            <!-- Services Table -->
            <table class="services-table luxury-table">
                <thead>
                    <tr>
                        <th class="center" style="width:8%">SR.NO</th>
                        <th class="left" style="width:25%">SERVICE</th>
                        <th class="left" style="width:35%">DELIVERABLES</th>
                        <th class="right" style="width:16%">PRICE</th>
                        <th class="right" style="width:16%">TOTAL</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (items && items.length> 0) { %>
                        <% items.forEach(function(item, idx) { %>
                            <tr>
                                <td class="col-sr" style="vertical-align: top; padding-top: 15px;">
                                    <%= idx + 1 %>
                                </td>
                                <td class="col-srv" style="vertical-align: top; padding-top: 15px; font-weight: 500;">
                                    <%= item.service %>
                                </td>
                                <td class="col-del" style="vertical-align: top; padding-top: 5px;">
                                    <% if (item.deliverables && item.deliverables.length > 0) { %>
                                        <ul style="margin: 0; padding-left: 15px; list-style-type: disc; color: #555; line-height: 1.6; font-size: 11px;">
                                            <% item.deliverables.forEach(function(d) { %>
                                                <li><%= d %></li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                </td>
                                <td class="col-price right" style="vertical-align: top; padding-top: 15px;">
                                    <%= item.price !=='-' ? item.price : '-' %>
                                </td>
                                <td class="col-total right" style="vertical-align: top; padding-top: 15px; font-weight: 500;">
                                    <%= item.total !=='-' ? item.total : '-' %>
                                </td>
                            </tr>
                            <% }); %>
                                <% } %>
                </tbody>
            </table>

            <!-- Bottom Section -->
            <div class="bottom-wrapper" style="margin-top: 30px; display: flex; justify-content: space-between; align-items: flex-start;">
                <!-- Left: Terms and Conditions -->
                <div class="terms-section" style="width: 55%; padding-right: 20px;">
                    <div class="terms-title" style="font-size: 11px; font-weight: 700; color: #111827; margin-bottom: 8px; text-transform: uppercase;">Terms & Conditions</div>
                    <ul class="terms-list" style="padding-left: 15px; font-size: 9px; line-height: 1.6; color: #6b7280; margin: 0; list-style-type: disc;">
                        <li><strong>Advance Payment:</strong> 50% advance payment required for booking.</li>
                        <li><strong>Balance Payment:</strong> Remaining balance due before the event date.</li>
                        <li><strong>Delivery:</strong> All edited deliverables will be provided within 3–4 weeks.</li>
                        <li><strong>Travel & Stay:</strong> Travel & accommodation outside the city are excluded.</li>
                        <li><strong>Raw Material:</strong> Raw footage and photos available upon request.</li>
                    </ul>
                </div>

                <!-- Right: Summary Totals exactly aligned -->
                <div class="summary-section" style="width: 40%;">
                    <table class="summary-table">
                        <tr>
                            <td class="s-label" style="text-align: left; font-size: 12px; color: #4b5563;">Subtotal</td>
                            <td class="s-val" style="text-align: right; font-size: 12px;">
                                <%= subtotal %>
                            </td>
                        </tr>
                        <tr>
                            <td class="s-label" style="text-align: left; font-size: 12px; color: #4b5563;">Taxes</td>
                            <td class="s-val" style="text-align: right; font-size: 12px;">
                                <%= tax %>
                            </td>
                        </tr>
                        <tr class="total-row">
                            <td class="s-label" style="text-align: left; font-weight: 700; font-size: 14px; color: #111827;">TOTAL</td>
                            <td class="s-val" style="text-align: right; font-weight: 700; font-size: 14px; color: #111827;">
                                <% if (String(total).includes('+')) { %>
                                    <% var parts = String(total).split('+'); %>
                                    <div><%= parts[0].trim() %></div>
                                    <div class="tax-hint" style="font-size: 10px; font-weight: normal; color: #b59048;">+ <%= parts[1].trim() %></div>
                                <% } else { %>
                                    <%= total %>
                                <% } %>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Footer -->
            <div class="footer-row" style="margin-top: auto; padding-top: 20px; font-size: 11px; color: #888; display: flex; justify-content: space-between;">
                <div class="footer-item"><span class="f-icon">📷</span> Aura Studio</div>
                <div class="footer-item"><span class="f-icon">📱</span> @auraweddings</div>
                <div class="footer-item"><span class="f-icon">📞</span> +91 080 234 5789</div>
                <div class="footer-item"><span class="f-icon">🌐</span> auraweddings.com</div>
            </div>

        </div> <!-- End of Page 1 -->

</body>

</html>